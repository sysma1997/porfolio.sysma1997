---
import Nav from "../../components/gum-fall/Nav.astro";
import t from "../../i18n/en.json";

import "../../styles/gum-fall/index.css";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/x-icon" href="/imgs/gum-fall-icon.png" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Gum Fall</title>
        <meta name="description" content="Gum Fall is a thrilling arcade game where you guide a character through moving platforms. Dodge obstacles, collect power-ups, and beat your high scores!" />
        <meta property="og:title" content="Gum Fall" />
        <meta property="og:description" content="Gum Fall is a thrilling arcade game where you guide a character through moving platforms. Dodge obstacles, collect power-ups, and beat your high scores!" />
        <meta property="og:image" content="https://sysma1997.github.io/imgs/gum-fall-cover-image.jpg" />
        <meta property="og:url" content="https://sysma1997.github.io/gum-fall/" />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="Gum Fall" />
        <meta name="twitter:description" content="Gum Fall is a thrilling arcade game where you guide a character through moving platforms. Dodge obstacles, collect power-ups, and beat your high scores!" />
        <meta name="twitter:image" content="https://sysma1997.github.io/imgs/gum-fall-cover-image.jpg" />
        <link rel="canonical" href="https://sysma1997.github.io/gum-fall/" />
        <link rel="alternate" hreflang="en" href="https://sysma1997.github.io/gum-fall/" />
        <link rel="alternate" hreflang="es" href="https://sysma1997.github.io/es/gum-fall/" />
        <link rel="alternate" hreflang="x-default" href="https://sysma1997.github.io/gum-fall/" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.15.1/devicon.min.css" />
        <script src="https://kit.fontawesome.com/c8146c06e1.js" crossorigin="anonymous"></script>
        <script is:inline>
            (function() {
                var saved = localStorage.getItem("theme");
                var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
                var theme = saved || (prefersDark ? "dark" : "light");
                document.documentElement.setAttribute("data-theme", theme);
            })();
        </script>
    </head>
    <body>
        <Nav lang="en" />

        <main id="gf-main">
            <div class="gf-content">
                <h1 class="gf-title">Gum Fall</h1>
                <img class="gf-cover" src="/imgs/gum-fall-cover-image.jpg" alt="Gum Fall cover" loading="lazy" />

                <div class="gf-description">
                    <p>{t.gumFall.p1}</p>
                <p>{t.gumFall.p2}</p>
                <p>{t.gumFall.p3}</p>
                <p>
                    {t.gumFall.features}
                    <ul>
                        <li>{t.gumFall.f1}</li>
                        <li>{t.gumFall.f2}</li>
                        <li>{t.gumFall.f3}</li>
                        <li>{t.gumFall.f4}</li>
                    </ul>
                </p>
                <p>{t.gumFall.cta}</p>
            </div>

            <div class="gf-links">
                <h2>{t.gumFall.download}</h2>
                <a class="gf-btn" href="https://play.google.com/store/apps/details?id=com.sysma1997.gumfall" target="_blank">
                    <i class="fab fa-google-play" />
                    {t.gumFall.download}
                </a>
                </div>
            </div>
        </main>

        <footer class="gf-footer">
            <a href="/gum-fall/privacy-polices">{t.gumFall.privacy}</a>
            <p>{t.gumFall.created} <b>SYSMA</b></p>
        </footer>
    </body>
</html>
