---
const { lang } = Astro.props as { lang: string };

const items = [
    { href: "#about", icon: "fas fa-user", key: "about" },
    { href: "#projects", icon: "fas fa-folder", key: "projects" },
    { href: "#skills", icon: "fas fa-star", key: "skills" },
    { href: "#works", icon: "fas fa-cubes", key: "works" },
    { href: "#contact", icon: "fas fa-inbox", key: "contact" },
];

const labels: Record<string, string> = {
    index: "Index", 
    about: "About", projects: "Projects", skills: "Skills",
    works: "Works", contact: "Contact",

    settings: "Settings", 
    language: "Language", en: "English", es: "Spanish", 
    theme: "Theme", light: "Light", dark: "Dark"
};

const labelsEs: Record<string, string> = {
    index: "Indice", 
    about: "Sobre mí", projects: "Proyectos", skills: "Habilidades",
    works: "Trabajos", contact: "Contacto",

    settings: "Configuración", 
    language: "Idioma", en: "Inglés", es: "Español", 
    theme: "Tema", light: "Claro", dark: "Oscuro"
};

const navLabels = lang === "es" ? labelsEs : labels;
const otherLang = lang === "es" ? "en" : "es";
---

<nav id="nav">
    <div class="container">
        <a class="brand" href={lang === "en" ? "/" : `/${lang}/`}>
            <span class="brand-text">SYSMA</span>
        </a>
    
        <div class="menu-right">
            <div class="dropdown main-dropdown">
                <button id="indexToggle" class="icon-btn dropdown-toggle" aria-label="Index">
                    <i class="fas fa-list"></i>
                </button>
                <ul id="indexLinks" class="links dropdown-menu">
                    {items.map((item) =>
                        <li>
                            <a href={item.href}>
                                <i class={item.icon} />
                                {navLabels[item.key]}
                            </a>
                        </li>
                    )}
                </ul>
            </div>
            <div class="dropdown actions-dropdown">
                <button id="actionsToggle" class="icon-btn dropdown-toggle" aria-label="Actions">
                    <i class="fas fa-cog"></i>
                </button>
                <ul id="actionsMenu" class="links dropdown-menu">
                    <li><a href={otherLang === "en" ? "/" : `/${otherLang}/`} class="lang-btn">
                        <i class="fas fa-language"></i>
                        {navLabels[lang]}
                    </a></li>
                    <li><a id="themeToggle" class="icon-btn" aria-label="Toggle theme">
                        <i class="fas fa-moon"></i>
                        {navLabels.theme}
                    </a></li>
                </ul>
            </div>
        </div>
    </div>

    <button id="toggleMenuMobile" class="icon-btn menu-toggle-button" aria-label="Toggle Menu">
        <i class="fas fa-bars"></i>
    </button>
    <div class="menu-side-mobile">
        <div class="menu-header">
            <h2>Menu</h2>
        </div>
        <ul>
            {items.map((item) =>
                <li>
                    <a href={item.href}>
                        <i class={item.icon} />
                        {navLabels[item.key]}
                    </a>
                </li>
            )}
            <li><a href={otherLang === "en" ? "/" : `/${otherLang}/`} class="lang-btn">
                <i class="fas fa-language"></i>
                {navLabels[lang]}
            </a></li>
            <li><a id="themeToggleMobile" class="icon-btn" aria-label="Toggle theme">
                <i class="fas fa-moon"></i>
                {navLabels.theme}
            </a></li>
        </ul>
    </div>
</nav>

<script define:vars={{navLabels}}>
    function toggleDropdown(menu) {
        menu.classList.toggle("show");
    }

    const indexToggle = document.getElementById("indexToggle");
    if (indexToggle) {
        indexToggle.onclick = () => toggleDropdown(indexToggle.nextElementSibling);
    }
    const actionsToggle = document.getElementById("actionsToggle");
    if (actionsToggle) {
        actionsToggle.onclick = () => toggleDropdown(actionsToggle.nextElementSibling);
    }

    const themeToggle = document.getElementById("themeToggle");
    if (themeToggle) {
        const stored = window.localStorage.getItem("theme");
        const icon = themeToggle.querySelector('i');
        if (icon) icon.className = stored === 'light' ? 'fas fa-sun' : 'fas fa-moon';
        themeToggle.onclick = () => {
            const newTheme = (window.localStorage.getItem("theme") === "dark") ? "light" : "dark";
            window.localStorage.setItem("theme", newTheme);
            document.documentElement.setAttribute("data-theme", newTheme);
            if (icon) icon.className = newTheme === 'light' ? 'fas fa-sun' : 'fas fa-moon';
            toggleDropdown(actionsToggle.nextElementSibling);
        };
    }

    document.getElementById("indexLinks")?.childNodes.forEach((element) => {
        try {
            element.onclick = () => toggleDropdown(indexToggle.nextElementSibling);
        } catch {}
    });

    const toggleMenuMobile = document.getElementById("toggleMenuMobile");
    if (toggleMenuMobile) {
        toggleMenuMobile.onclick = () => {
            const menuSide = document.querySelector(".menu-side-mobile");
            if (menuSide) {
                menuSide.classList.toggle("open");
            }
        };
    }
    const themeToggleMobile = document.getElementById("themeToggleMobile");
    if (themeToggleMobile) {
        const stored = window.localStorage.getItem("theme");
        const icon = themeToggleMobile.querySelector('i');
        if (icon) icon.className = stored === 'light' ? 'fas fa-sun' : 'fas fa-moon';
        themeToggleMobile.onclick = () => {
            const newTheme = (window.localStorage.getItem("theme") === "dark") ? "light" : "dark";
            window.localStorage.setItem("theme", newTheme);
            document.documentElement.setAttribute("data-theme", newTheme);
            if (icon) icon.className = newTheme === 'light' ? 'fas fa-sun' : 'fas fa-moon';
            const menuSide = document.querySelector(".menu-side-mobile");
            if (menuSide) {
                menuSide.classList.remove("open");
            }
        };
    }

    document.addEventListener('click', (event) => {
        const isClickOutside = !event.target.closest(".dropdown");
        if (isClickOutside) {
            document.querySelectorAll(".dropdown-menu").forEach((menu) => {
                menu.classList.remove("show");
            });
        }
        if (!event.target.closest("#toggleMenuMobile")) {
            const menuSide = document.querySelector(".menu-side-mobile");
            if (menuSide) {
                menuSide.classList.remove("open");
            }
        }
    });
</script>

<style>
    #nav {
        background: var(--bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);

        padding: 0 2rem;
        height: 64px;

        display: flex;
        align-items: center;
        justify-content: center;
        
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
    }
    #nav .container {
        width: 70%;

        display: flex;
        justify-content: space-between;
    }
    #nav .menu-toggle-button {
        background-color: var(--bg-card);
        border-radius: var(--radius-sm);
        color: var(--text-secondary);
        font-size: 1.2rem;
        border: none;
        padding: 0.5rem 1rem;
        
        display: none;
        
        cursor: pointer;
        
        transition: all var(--transition);
    }
    #nav .menu-toggle-button:hover {
        background-color: var(--bg);
    }

    .brand { text-decoration: none; }
    .brand-text {
        font-size: 1.4rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: 0.05em;
    }

    .menu-right {
        display: flex;
        flex-direction: row;
        gap: 1rem;
    }

    .dropdown {
        position: relative;
    }
    
    .dropdown-toggle {
        background: var(--bg);
        color: var(--text-secondary);
        border-radius: var(--radius-sm);
        text-decoration: none;
        font-size: 1.1rem;
        font-family: var(--font);
        font-weight: 700;
        border: none;
        padding: 0.5rem 0.6rem;

        display: inline-flex;
        justify-content: center;
        align-items: center;

        cursor: pointer;
        transition: all var(--transition);
    }
    
    .dropdown-toggle:hover {
        color: var(--text);
        background: var(--bg-card);
    }

    .dropdown-menu {
        background-color: var(--bg);
        border-radius: var(--radius-sm);
        box-shadow: 0 8px 16px 0 rgba(0,0,0,0.2);
        padding: 12px 16px;
        width: auto;
        min-width: 160px;

        position: absolute;
        top: 100%;
        left: 0;
        z-index: 100;

        visibility: hidden;
        opacity: 0;
        transform: translateY(-8px);
        transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    }
    
    .dropdown-menu.show {
        visibility: visible;
        opacity: 1;
        transform: translateY(0);
    }

    .links {
        list-style: none;
    }
    .links li {
        cursor: pointer;
    }
    .links a {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-sm);
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        transition: all var(--transition);
    }
    .links a:hover {
        color: var(--text);
        background: var(--bg-card);
    }

    .menu-side-mobile {
        background-color: var(--bg);
        box-shadow: 2px 0 8px rgba(0,0,0,0.2);
        width: 250px;
        height: 100vh;

        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;

        transform: translateX(-100%);
        transition: transform 0.3s ease-in-out;
    }
    .menu-side-mobile.open {
        transform: translateX(0);
    }
    .menu-side-mobile .menu-header {
        background-color: var(--bg-card);
        padding: 0.5rem;
        text-align: center;
        border-bottom: 1px solid var(--border);
    }
    .menu-side-mobile .menu-header h2 {
        margin: 0;
        font-size: 1.2rem;
        color: var(--text-secondary);
    }

    .menu-side-mobile ul {
        list-style-type: none;
        padding: 0;
    }

    .menu-side-mobile a {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-sm);
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        transition: all var(--transition);
    }

    .menu-side-mobile a:hover {
        color: var(--text);
        background: var(--bg-card);
    }

    @media (max-width: 850px) {
        #nav {
            padding: 1rem;
        }
        #nav .container {
            width: 90%;
        }
        #nav .menu-right {
            display: none;
        }
        #nav .menu-toggle-button {
            display: block;
            margin-left: auto;
        }
    }
</style>
